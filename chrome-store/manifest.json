{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "1.5.0",
  "default_locale": "zh_CN",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "author": "Un1quer",
  "permissions": ["search"],
  "homepage_url": "https://github.com/Un1quer23/WillowTab",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "optional_host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://www.baidu.com/*",
    "https://api.bing.com/*",
    "https://duckduckgo.com/*"
  ]
}
